FROM golang:1.26 AS build
WORKDIR /src
COPY provider-sdk ./provider-sdk
COPY providers/app-studio ./providers/app-studio
WORKDIR /src/providers/app-studio
RUN go build -o /out/sandbox-runner ./runner

FROM node:22-bookworm
RUN apt-get update && apt-get install -y ca-certificates git && rm -rf /var/lib/apt/lists/*
COPY --from=build /out/sandbox-runner /usr/local/bin/sandbox-runner
WORKDIR /workspace
EXPOSE 3000 7070
ENTRYPOINT ["/usr/local/bin/sandbox-runner"]
