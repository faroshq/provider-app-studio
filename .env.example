# Local-dev environment for the kedge "app-studio" provider.
#
# Copy to providers/app-studio/.env only when you need to override defaults.
# `make run-provider-app-studio` and both Tiltfiles auto-source the gitignored
# .env file, so no manual `export` is needed.
#
# By default, local dev starts a Postgres container named
# kedge-app-studio-postgres and points App Studio at it. Conversation history
# survives provider restarts and hard refreshes because it uses the same
# Postgres-backed store path as production.
#
# Use an existing Postgres instead of the local dev container.
# APP_STUDIO_DATABASE_URL=postgres://appstudio:appstudio@localhost:55432/appstudio?sslmode=disable
#
# Force old non-durable behavior for one-off UI work.
# APP_STUDIO_IN_MEMORY_MESSAGE_STORE=true
#
# Optional message-store controls.
# APP_STUDIO_MESSAGE_RETENTION=720h
# APP_STUDIO_MESSAGE_ENCRYPTION_KEYS=primary:<base64-32-byte-aes-key>
#
# Project workspace files used by App Studio local file tools.
# APP_STUDIO_WORKSPACE_ROOT=.kcp/app-studio-workspaces
#
# Enable companion SandboxPreviewHTTPRoute resources for newly created projects.
# This mints the infrastructure object and preview host metadata for the
# Gateway API route that points to the shared preview gateway service.
# APP_STUDIO_PREVIEW_BASE_DOMAIN=preview.localhost
# APP_STUDIO_PREVIEW_HTTPROUTE_PARENT_GATEWAY_NAME=app-studio-preview
# APP_STUDIO_PREVIEW_HTTPROUTE_PARENT_GATEWAY_NAMESPACE=envoy-gateway-system
# APP_STUDIO_PREVIEW_HTTPROUTE_PARENT_GATEWAY_SECTION_NAME=app-studio-preview-https
# APP_STUDIO_PREVIEW_BACKEND_NAMESPACE=kedge-preview
# APP_STUDIO_PREVIEW_BACKEND_SERVICE_NAME=sandbox-preview-gateway
# APP_STUDIO_PREVIEW_BACKEND_SERVICE_PORT=8080
# APP_STUDIO_PREVIEW_PUBLIC_PORT=10443
# APP_STUDIO_PREVIEW_TOKEN_SECRET=dev-app-studio-preview-token-secret
